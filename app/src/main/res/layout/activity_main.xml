<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp"
    android:background="#F5F5F5">

    <!-- High Score Display -->
    <TextView
        android:id="@+id/high_score_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="High Score: 0"
        android:textSize="16sp"
        android:textColor="#666666"
        android:layout_marginBottom="16dp" />

    <!-- Score Display -->
    <TextView
        android:id="@+id/score_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Score: 0"
        android:textSize="20sp"
        android:textColor="#2196F3"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <!-- Question Counter -->
    <TextView
        android:id="@+id/question_counter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Question: 1/15"
        android:textSize="16sp"
        android:textColor="#666666"
        android:layout_marginBottom="32dp" />

    <!-- Question Text -->
    <TextView
        android:id="@+id/question_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Loading question..."
        android:textSize="20sp"
        android:textColor="#333333"
        android:textAlignment="center"
        android:padding="16dp"
        android:background="@drawable/question_background"
        android:layout_marginBottom="48dp"
        android:lineSpacingMultiplier="1.2" />

    <!-- New: Multiple Choice Buttons using GridLayout -->
    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="2"
        android:rowCount="2"
        android:orientation="horizontal"
        android:layout_gravity="center"
        android:alignmentMode="alignBounds"
        android:columnOrderPreserved="false">

        <Button
            android:id="@+id/option_button_a"
            android:layout_width="0dp"
            android:layout_columnWeight="1"
            android:layout_height="60dp"
            android:text="Option A"
            android:textSize="16sp"
            android:textStyle="bold"
            android:backgroundTint="#64B5F6"
            android:textColor="@android:color/white"
            android:layout_margin="8dp"
            android:elevation="4dp"
            android:textAllCaps="false" />

        <Button
            android:id="@+id/option_button_b"
            android:layout_width="0dp"
            android:layout_columnWeight="1"
            android:layout_height="60dp"
            android:text="Option B"
            android:textSize="16sp"
            android:textStyle="bold"
            android:backgroundTint="#64B5F6"
            android:textColor="@android:color/white"
            android:layout_margin="8dp"
            android:elevation="4dp"
            android:textAllCaps="false" />

        <Button
            android:id="@+id/option_button_c"
            android:layout_width="0dp"
            android:layout_columnWeight="1"
            android:layout_height="60dp"
            android:text="Option C"
            android:textSize="16sp"
            android:textStyle="bold"
            android:backgroundTint="#64B5F6"
            android:textColor="@android:color/white"
            android:layout_margin="8dp"
            android:elevation="4dp"
            android:textAllCaps="false" />

        <Button
            android:id="@+id/option_button_d"
            android:layout_width="0dp"
            android:layout_columnWeight="1"
            android:layout_height="60dp"
            android:text="Option D"
            android:textSize="16sp"
            android:textStyle="bold"
            android:backgroundTint="#64B5F6"
            android:textColor="@android:color/white"
            android:layout_margin="8dp"
            android:elevation="4dp"
            android:textAllCaps="false" />

    </GridLayout>

</LinearLayout>